# Учётные данные VFS Global
VFS_EMAIL=your.email@example.com
VFS_PASSWORD=your_password_here

# URL страницы входа
VFS_LOGIN_URL=https://visa.vfsglobal.com/blr/ru/pol/login

# API-ключ RuCaptcha для обхода Cloudflare Turnstile (https://rucaptcha.com/)
RU_CAPCHA_API=

# Интервал проверки страницы (секунды)
CHECK_INTERVAL_SEC=60

# Пауза после перехода со страницы 403 (секунды)
POST_403_NAV_WAIT_SEC=5

# Таймаут ожидания элементов (секунды)
BROWSER_TIMEOUT_SEC=30

# Режим браузера: true — без окна, false — с окном
HEADLESS=false

# undetected-chromedriver — обход детекции Cloudflare (рекомендуется true)
USE_UNDETECTED_CHROME=true

# Папка профиля Chrome (сохранение cookies между запусками)
CHROME_USER_DATA_DIR=

# Логирование: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
